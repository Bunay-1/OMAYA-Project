# Example environment variables for OMAYA Platform
# Copy this file to .env and fill in secure values before running

# Platform metadata
PLATFORM_VERSION=3.1.6

# TimescaleDB / Postgres
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5432
TIMESCALE_USER=omaya_user
TIMESCALE_PASSWORD=__REPLACE_ME_STRONG_PASSWORD__
TIMESCALE_DB=omaya_monitoring

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Grafana admin credentials (DO NOT use default admin/admin in production)
GRAFANA_ADMIN_USER=__REPLACE_ME__
GRAFANA_ADMIN_PASSWORD=__REPLACE_ME_STRONG_PASSWORD__

# MinIO credentials (replace before production)
MINIO_ROOT_USER=__REPLACE_ME__
MINIO_ROOT_PASSWORD=__REPLACE_ME_STRONG_PASSWORD__

# Vault (do NOT use dev token in production)
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=__REPLACE_ME__

# CORS allowed origins (comma separated)
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# Frontend config (Vite)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
VITE_USE_MOCK=true

# Application secrets
JWT_SECRET=__REPLACE_ME_RANDOM_SECRET__

# Notes:
# - Replace all __REPLACE_ME__ placeholders before running in production.
# - Never commit your filled .env file into source control.
