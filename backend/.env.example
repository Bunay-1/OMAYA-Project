# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_USERNAME=
KAFKA_PASSWORD=

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Authentication
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5432
TIMESCALE_DB=omaya_monitoring
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=

# AI Models
MODEL_PATH=./models
ENABLE_AI_PREDICTIONS=true

# Monitoring
PROMETHEUS_PORT=9090
ENABLE_METRICS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60

# Data Lake (MinIO/S3)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Secrets Management
SECRETS_BACKEND=env
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-token
VAULT_NAMESPACE=omaya-monitoring

# TLS Configuration
CERTS_DIR=/etc/ssl/omaya
TLS_ENABLED=false

# Audit Trail
AUDIT_STORAGE=file
AUDIT_LOG_DIR=./audit_logs
AUDIT_RETENTION_DAYS=365
AUDIT_BUFFER_SIZE=100

# Multi-Region
PRIMARY_REGION=eu-west-1
CURRENT_REGION=eu-west-1

# Service Mesh
SERVICE_MESH=istio
K8S_NAMESPACE=omaya-monitoring
MTLS_ENABLED=true

# AWS Configuration (for AWS deployments)
AWS_REGION=us-east-1
