# OMAYA High Availability Environment Variables
# Copy this to .env and fill in the values

# Global
JWT_SECRET=generate-a-secure-random-string-here

# Database
TIMESCALE_USER=omaya_user
TIMESCALE_PASSWORD=omaya_secure_password
TIMESCALE_DB=omaya_monitoring
TIMESCALE_REPLICATION_USER=omaya_replicator
TIMESCALE_REPLICATION_PASSWORD=omaya_replication_secure_password

# Redis
REDIS_PASSWORD=omaya_redis_secure_password

# Kafka / Zookeeper
# Usually no passwords for internal dev HA, but can be added if needed
